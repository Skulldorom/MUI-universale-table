{
  "name": "mui-universale-table",
  "version": "2.0.2",
  "description": "A universal table component built with Material UI for React applications",
  "keywords": [
    "react",
    "material-ui",
    "mui",
    "table",
    "component",
    "typescript"
  ],
  "license": "MIT",
  "author": "Skulldorom",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.esm.js",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "rollup -c",
    "dev": "rollup -c -w",
    "prepare": "npm run build",
    "test": "node --experimental-vm-modules node_modules/jest-cli/bin/jest.js",
    "test:watch": "node --experimental-vm-modules node_modules/jest-cli/bin/jest.js --watch",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix"
  },
  "peerDependencies": {
    "@emotion/react": "^11.5.0",
